# Port publik yang diekspos container ke host (default 80)
PUBLIC_PORT=80

# Backend runtime
NODE_ENV=production
PORT=4000
JWT_SECRET=GANTI_DENGAN_SECRET_ACAK_MIN_32_KARAKTER

# Domain aplikasi Anda — dipakai header CORS untuk API client non-browser
CORS_ORIGIN=https://absensi.example.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
